rules_version = '2';

// Reglas de seguridad de Firestore para Flores Travel Agency.
// Publícalas en: Firebase Console → Firestore Database → Reglas
// (o con `firebase deploy --only firestore:rules` si usas la CLI).
//
// Lectura pública (los visitantes ven los viajes); escritura solo
// para usuarios autenticados (el panel #admin).
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Solicitudes de contacto: cualquier visitante puede crear una,
    // pero solo el equipo (autenticado) puede leerlas o borrarlas.
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'phone', 'tripId', 'tripTitle', 'message', 'createdAt'])
                    && request.resource.data.name is string && request.resource.data.name.size() <= 120
                    && request.resource.data.phone is string && request.resource.data.phone.size() <= 30
                    && request.resource.data.message is string && request.resource.data.message.size() <= 1000;
      allow read, update, delete: if request.auth != null;
    }
  }
}
